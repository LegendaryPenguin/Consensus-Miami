# --- Paid agent API (apps/paid-agent-api) ---
# API reads PAYMENT_MODE first, then falls back to TOLLGATE_PAYMENT_MODE if unset.
# Use PAYMENT_MODE=mock for Phase 4?5 / Cursor mock demos.
# Use PAYMENT_MODE=x402 for Phase 7 real x402 seller paywall (requires real testnet SELLER_WALLET_ADDRESS).
PAYMENT_MODE=mock
PORT=4000

# x402 seller (testnet). Required when PAYMENT_MODE=x402 ? placeholders will fail startup.
X402_NETWORK=eip155:84532
X402_FACILITATOR_URL=https://x402.org/facilitator
SELLER_WALLET_ADDRESS=0xYourRealBaseSepoliaSellerAddress
PRICE_USD=0.003
USE_BEDROCK=false
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=arn:aws:bedrock:us-east-1:432780980220:inference-profile/global.amazon.nova-2-lite-v1:0

# Same value on paid-agent-api and dashboard (server-only). Protects /seller/* CRUD and ledger APIs.
SELLER_DEMO_SECRET=change-me-seller-demo

# --- MCP server (apps/mcp-server) ---
# Default tool payment behavior when paymentMode is omitted from tollgate_call_paid_agent.
TOLLGATE_API_URL=http://localhost:4000
TOLLGATE_PAYMENT_MODE=mock

# --- Dashboard (apps/dashboard) ---
# Used by client polling for timeline/events and server fallback route endpoint resolution.
NEXT_PUBLIC_TOLLGATE_API_URL=http://localhost:4000
NEXT_PUBLIC_PAYMENT_MODE=mock
# Public buyer address for dashboard USDC balance (no private key in browser; read via /api/balance)
NEXT_PUBLIC_BUYER_WALLET_ADDRESS=
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
TOLLGATE_PAID_API_URL=http://localhost:4000
TOLLGATE_MOCK_API_URL=http://localhost:4000
SELLER_DEMO_SECRET=change-me-seller-demo

# Required for real x402 buyer flow in Phase 8+.
# Use a testnet-only private key and never commit real keys.
BUYER_WALLET_PRIVATE_KEY=0xyour_testnet_private_key
