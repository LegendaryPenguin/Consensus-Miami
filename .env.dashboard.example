# Public dashboard environment
NEXT_PUBLIC_TOLLGATE_API_URL=https://YOUR_PUBLIC_API_URL
NEXT_PUBLIC_PAYMENT_MODE=x402

# Buyer wallet (public only) for the top-bar USDC balance chip via GET /api/balance
NEXT_PUBLIC_BUYER_WALLET_ADDRESS=0xYourBaseSepoliaBuyerAddress

# Seller wallet for on-chain transaction history (buyer -> seller USDC transfers)
NEXT_PUBLIC_SELLER_WALLET_ADDRESS=0xYourBaseSepoliaSellerAddress

# Server-only RPC for balance reads (defaults to https://sepolia.base.org if unset)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Optional start block to limit history scanning cost/time
# TX_HISTORY_START_BLOCK=40000000

# Optional split endpoints for fallback route behavior
TOLLGATE_PAID_API_URL=https://YOUR_PUBLIC_API_URL
TOLLGATE_MOCK_API_URL=http://localhost:4000
